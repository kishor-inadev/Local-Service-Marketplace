# Environment variables for docker-compose

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace

# Redis (default connection, no password)
REDIS_HOST=redis
REDIS_PORT=6379

# Database Connection Pool
DB_POOL_MAX=30
DB_POOL_MIN=5

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=marketplace-service
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# Feature Flags
EVENT_BUS_ENABLED=false
CACHE_ENABLED=false

# Service Ports (internal)
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
REQUEST_SERVICE_PORT=3003
PROPOSAL_SERVICE_PORT=3004
JOB_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
MESSAGING_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
REVIEW_SERVICE_PORT=3009
ADMIN_SERVICE_PORT=3010
ANALYTICS_SERVICE_PORT=3011
INFRASTRUCTURE_SERVICE_PORT=3012

# API Gateway
API_GATEWAY_PORT=3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Node Environment
NODE_ENV=production
