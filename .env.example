# ===============================================
# LOCAL SERVICE MARKETPLACE
# Environment Configuration for Docker Compose
# ===============================================

# -----------------------------------------------
# SECURITY (CRITICAL - CHANGE IN PRODUCTION)
# -----------------------------------------------

# JWT Secret - MUST be at least 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production-min-32-chars

# Gateway Internal Secret (for auth service communication)
# Used by API Gateway to securely call auth service /auth/verify endpoint
GATEWAY_INTERNAL_SECRET=gateway-internal-secret-change-in-production

# Token Validation Strategy
# Options: 'local' (JWT verification in gateway) or 'api' (call auth service)
# 'local' = faster, lower latency, gateway needs JWT_SECRET
# 'api' = centralized, can check user status, auth service dependency
TOKEN_VALIDATION_STRATEGY=local

# -----------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------

# PostgreSQL Configuration (Docker Compose Only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace

# Connection Pool Settings (All Services)
# Via PgBouncer (Docker): each service pool × 6 = 60 client conns → 25 actual DB conns
DB_POOL_MAX=10
DB_POOL_MIN=2

# -----------------------------------------------
# REDIS (Cache & Queue)
# -----------------------------------------------

# Redis Configuration
# Use 'redis' for Docker, 'localhost' for local development
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Full Redis URL (alternative to host/port)
# REDIS_URL=redis://redis:6379

# -----------------------------------------------
# KAFKA & ZOOKEEPER (Event Streaming)
# -----------------------------------------------

# Kafka Configuration
# Use 'kafka:29092' for Docker internal, 'localhost:9092' for external
KAFKA_BROKERS=kafka:29092
KAFKA_CLIENT_ID=marketplace-service

# Zookeeper Configuration
ZOOKEEPER_HOST=zookeeper
ZOOKEEPER_PORT=2181

# -----------------------------------------------
# SCALING CONFIGURATION (Levels 1-5)
# -----------------------------------------------
# Enable infrastructure layers based on your scaling needs:
# 
# Level 1 (MVP): All disabled - 200-350 concurrent users
#   - 11 core services only
#   - ~3-5 GB memory
#   - Email notifications only
# 
# Level 2 (Cache): CACHE_ENABLED=true - 500-1K users
#   - Add Redis for caching
#   - ~4-6 GB memory
#   - 2x faster API responses
# 
# Level 3 (Workers): CACHE_ENABLED=true, WORKERS_ENABLED=true - 2K+ users
#   - Add background job processing
#   - ~5-7 GB memory
#   - Async email sending, payment processing
# 
# Level 4 (Events): All above + EVENT_BUS_ENABLED=true - 10K+ users
#   - Add Kafka event streaming
#   - ~8-10 GB memory
#   - Event-driven microservices communication
# 
# Level 5 (Full Scale): All enabled + Kubernetes + CDN - 50K+ users
#   - Add messaging, analytics, infrastructure services
#   - ~12-16 GB memory
#   - Horizontal scaling, monitoring, advanced features

# Feature Flags - Infrastructure Scaling
CACHE_ENABLED=false              # Level 2: Redis caching for frequently accessed data
WORKERS_ENABLED=false            # Level 3: Background job processing with Bull queues
EVENT_BUS_ENABLED=false          # Level 4: Kafka event-driven architecture
BACKGROUND_JOBS_ENABLED=false    # Infrastructure service background jobs
RATE_LIMITING_ENABLED=true       # Rate limiting (always enabled)
FEATURE_FLAGS_ENABLED=true       # Feature flag system (always enabled)

# Feature Flags - Optional Services
ANALYTICS_ENABLED=false          # Custom analytics service (use Google Analytics for MVP)
INFRASTRUCTURE_ENABLED=false     # Infrastructure service (use external tools for MVP)
MESSAGING_ENABLED=false          # In-app messaging/chat (not needed for MVP)
FRONTEND_ENABLED=false           # Next.js frontend application (use npm run dev for development)
API_GATEWAY_ENABLED=true         # API Gateway (required for backend API access)

# -----------------------------------------------
# NOTIFICATION CONFIGURATION
# -----------------------------------------------

# Notification Channels
EMAIL_ENABLED=false               # Email notifications (always enabled for MVP)
SMS_ENABLED=false                # SMS notifications (optional, costs money)

# Advanced Notification Features (MVP: all disabled)
IN_APP_NOTIFICATIONS_ENABLED=false       # In-app notification center
PUSH_NOTIFICATIONS_ENABLED=false         # Browser/mobile push notifications
NOTIFICATION_PREFERENCES_ENABLED=false   # User notification preferences
DEVICE_TRACKING_ENABLED=false            # User device tracking

# -----------------------------------------------
# EMAIL & SMS CONFIGURATION
# -----------------------------------------------
# NOTE: Email and SMS delivery is now handled by external microservices on Vercel.
# Configs like EMAIL_HOST, EMAIL_USER, TWILIO_*, AWS_* are configured there.

# SMS API Key (Used by comms-service to authenticate with external sms-service)
SMS_API_KEY=change-me-to-a-strong-random-secret

# -----------------------------------------------
# SERVICE PORTS (Internal Docker Network)
# -----------------------------------------------

# Core Backend Services
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
REQUEST_SERVICE_PORT=3003
PROPOSAL_SERVICE_PORT=3004
JOB_SERVICE_PORT=3005
PAYMENT_SERVICE_PORT=3006
MESSAGING_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
REVIEW_SERVICE_PORT=3009
ADMIN_SERVICE_PORT=3010

# Optional Services
ANALYTICS_SERVICE_PORT=3011
INFRASTRUCTURE_SERVICE_PORT=3012

# -----------------------------------------------
# API GATEWAY CONFIGURATION
# -----------------------------------------------

# API Gateway Port (External Access)
API_GATEWAY_PORT=3700

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000       # 1 minute window
RATE_LIMIT_MAX_REQUESTS=100      # 100 requests per minute per IP

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------
# OAUTH PROVIDERS
# -----------------------------------------------

# Google OAuth
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3700/api/v1/user/auth/google/callback

# Facebook OAuth
# Get credentials from: https://developers.facebook.com/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3700/api/v1/user/auth/facebook/callback

# -----------------------------------------------
# FRONTEND CONFIGURATION
# -----------------------------------------------

# Frontend Application
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3001

# Frontend Environment Variables (passed to Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3700
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# -----------------------------------------------
# APPLICATION ENVIRONMENT
# -----------------------------------------------

# Node Environment
# Options: development, production, test
NODE_ENV=production

# Application Name (used in emails, notifications)
APPLICATION_NAME=Local Service Marketplace

# -----------------------------------------------
# OPTIONAL: ADVANCED CONFIGURATION
# -----------------------------------------------


# Logging
LOG_LEVEL=info
ENABLE_LOGGING=true

# Tenancy (Multi-tenant support - future feature)
TENANCY_ENABLED=false
DEFAULT_TENANT_ID=marketplace

# -----------------------------------------------
# NOTES
# -----------------------------------------------
# 
# 1. This file is for docker-compose.yml usage
# 2. Copy to .env and customize for your environment
# 3. Never commit .env file to version control
# 4. For production: Use environment-specific secrets management
# 5. Each microservice has its own .env.example in services/*/
# 
# For detailed configuration guide, see:
# - docs/MVP_STARTUP_GUIDE.md
# - docs/IMPLEMENTATION_STATUS_REPORT.md
# - docs/ENVIRONMENT_VARIABLES_AUDIT_REPORT.md
