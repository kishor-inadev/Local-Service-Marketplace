# ===============================================
# MESSAGING SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3007
SERVICE_NAME=messaging-service

# Database - PostgreSQL
# For Docker: Use container name 'postgres', port 5432
# For Local: Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace

# Connection Pooling
DB_POOL_MAX=30
DB_POOL_MIN=5

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# File Upload Configuration
MAX_FILE_SIZE=5242880  # 5MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Redis Configuration (Optional - for caching)
# For Docker: redis://redis:6379
# For Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration (Optional - for event streaming)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=messaging-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false

# Logging
LOG_LEVEL=info
