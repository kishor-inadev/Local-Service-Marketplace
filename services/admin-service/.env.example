# ===============================================
# ADMIN SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3010
SERVICE_NAME=admin-service

# Database - PostgreSQL
# For Docker: Use container name 'postgres', port 5432
# For Local: Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace

# Connection Pooling
DB_POOL_MAX=30
DB_POOL_MIN=5

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# Admin Configuration
ADMIN_EMAIL=admin@marketplace.com
ADMIN_PASSWORD=change-this-admin-password

# Redis Configuration (Optional - for caching)
# For Docker: redis://redis:6379
# For Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration (Optional - for event streaming)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=admin-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false

# Logging
LOG_LEVEL=info
