# ===============================================
# INFRASTRUCTURE SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3012
SERVICE_NAME=infrastructure-service

# Database - PostgreSQL
# For Docker: Use container name 'postgres', port 5432
# For Local: Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace

# Connection Pooling
DB_POOL_MAX=30
DB_POOL_MIN=5

# Redis Configuration (only needed if CACHE_ENABLED=true)
# For Docker: redis
# For Local: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Kafka Configuration (only needed if EVENT_BUS_ENABLED=true)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=infrastructure-service

# Feature Flags - For MVP Launch
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
BACKGROUND_JOBS_ENABLED=false
RATE_LIMITING_ENABLED=true
FEATURE_FLAGS_ENABLED=true

# Logging
LOG_LEVEL=info
