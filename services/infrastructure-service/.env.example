# ===============================================
# INFRASTRUCTURE SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3012
SERVICE_NAME=infrastructure-service

# Database - PostgreSQL
# Docker Compose: Use container name 'pgbouncer' (PgBouncer pooler fronting postgres)
# Local dev (outside Docker): Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
# Docker URL: postgresql://postgres:postgres_dev_only@pgbouncer:5432/marketplace

# Connection Pooling
# Kept low — PgBouncer (transaction mode) multiplexes to 25 actual backend connections
DB_POOL_MAX=10
DB_POOL_MIN=2

# Redis Configuration (only needed if CACHE_ENABLED=true)
# For Docker: redis
# For Local: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Kafka Configuration (only needed if EVENT_BUS_ENABLED=true)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=infrastructure-service

# Feature Flags - For MVP Launch
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
BACKGROUND_JOBS_ENABLED=false
RATE_LIMITING_ENABLED=true
FEATURE_FLAGS_ENABLED=true

# Logging
LOG_LEVEL=info
FILE_UPLOAD_SERVICE_URL=http://localhost:4100
FILE_DEFAULT_TENANT_ID=default
REQUEST_TIMEOUT_MS=72000