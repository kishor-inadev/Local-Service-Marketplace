# ===============================================
# MARKETPLACE SERVICE CONFIGURATION (request + proposal + job + review)
# ===============================================

# Application
NODE_ENV=development
PORT=3003
SERVICE_NAME=marketplace-service

# Database - PostgreSQL
# Docker Compose: DATABASE_HOST=pgbouncer  (traffic is pooled via PgBouncer)
# Local dev (outside Docker): DATABASE_HOST=localhost
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
# Docker URL: postgresql://postgres:postgres_dev_only@pgbouncer:5432/marketplace

# Connection Pooling
# Kept low — PgBouncer (transaction mode) multiplexes to 25 actual backend connections
DB_POOL_MAX=10
DB_POOL_MIN=2

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# Service Communication
# For Docker: http://identity-service:3001, http://comms-service:3007
# For Local: http://localhost:3001, http://localhost:3007
USER_SERVICE_URL=http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3007

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=marketplace-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false

# Logging
LOG_LEVEL=info

FILE_UPLOAD_SERVICE_URL=http://localhost:4100
FILE_DEFAULT_TENANT_ID=default