# ===============================================
# AUTH SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service

# Database - PostgreSQL
# For Docker: Use container name 'postgres', port 5432
# For Local: Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace

# Connection Pooling
DB_POOL_MAX=30
DB_POOL_MIN=5

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Gateway Internal Secret (for API Gateway communication)
GATEWAY_INTERNAL_SECRET=gateway-internal-secret-change-in-production

# Email (for verification tokens)
EMAIL_FROM=noreply@marketplace.com
EMAIL_VERIFICATION_EXPIRES_IN=24h
PASSWORD_RESET_EXPIRES_IN=1h

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=15m

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3500/api/v1/auth/google/callback

# OAuth - Facebook
# Get credentials from: https://developers.facebook.com/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3500/api/v1/auth/facebook/callback

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Service Communication (Docker: use container names, Local: use localhost)
# For Docker: http://notification-service:3008
# For Local: http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3008

# SMS Service Configuration (Twilio)
# Set SMS_SERVICE_ENABLED=true to enable OTP via SMS
SMS_SERVICE_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email Service Configuration (SMTP)
# Set EMAIL_SERVICE_ENABLED=true to enable OTP via Email
EMAIL_SERVICE_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@marketplace.com

# Redis Configuration (Optional - for caching)
# For Docker: redis://redis:6379
# For Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration (Optional - for event streaming)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false

# Logging
LOG_LEVEL=info
