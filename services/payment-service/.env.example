# ===============================================
# PAYMENT SERVICE CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3006
SERVICE_NAME=payment-service

# Database - PostgreSQL
# Docker Compose: Use container name 'pgbouncer' (PgBouncer pooler fronting postgres)
# Local dev (outside Docker): Use 'localhost', port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=marketplace
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketplace
# Docker URL: postgresql://postgres:postgres_dev_only@pgbouncer:5432/marketplace

# Connection Pooling
# Kept low — PgBouncer (transaction mode) multiplexes to 25 actual backend connections
# Preferred pool controls
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_QUERY_TIMEOUT_MS=30000

# Backward-compatible legacy controls
DB_POOL_MAX=10
DB_POOL_MIN=2

# Pagination
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# Payment Gateway Configuration
# -----------------------------------------------
# Select which gateway to use: stripe | razorpay | paypal | mock
# "mock" is the default when credentials are missing (safe for dev/CI)
PAYMENT_GATEWAY=mock

# Stripe
# Set PAYMENT_GATEWAY=stripe and provide the key below to enable.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_RETURN_URL=http://localhost:3000/payment/confirm

# Razorpay
# Set PAYMENT_GATEWAY=razorpay and provide the keys below.
# Webhook URL: POST /webhooks/razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PayPal
# Set PAYMENT_GATEWAY=paypal and provide the credentials below.
# Use PAYPAL_API_URL=https://api-m.paypal.com for production.
# Webhook URL: POST /webhooks/paypal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# PayUbiz (PayU India)
# Set X-Payment-Gateway: payubiz header on POST /payments to use this gateway.
# Webhook URL for success/failure: POST /webhooks/payubiz
# Use PAYU_API_URL=https://secure.payu.in for production.
PAYU_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_salt
PAYU_SUCCESS_URL=http://localhost:3006/webhooks/payubiz
PAYU_FAILURE_URL=http://localhost:3006/webhooks/payubiz
PAYU_API_URL=https://test.payu.in

# Instamojo
# Set X-Payment-Gateway: instamojo header on POST /payments to use this gateway.
# Webhook URL: POST /webhooks/instamojo
# Use INSTAMOJO_API_URL=https://api.instamojo.com for production.
INSTAMOJO_API_KEY=your_instamojo_api_key
INSTAMOJO_AUTH_TOKEN=your_instamojo_auth_token
INSTAMOJO_SALT=your_instamojo_salt
INSTAMOJO_WEBHOOK_URL=http://localhost:3006/webhooks/instamojo
INSTAMOJO_REDIRECT_URL=http://localhost:3000/payment/confirm
INSTAMOJO_API_URL=https://test.instamojo.com

# Service Communication (Docker: use container names, Local: use localhost)
# For Docker: http://notification-service:3008
# For Local: http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3008

# Redis Configuration (Optional - for caching and queues)
# For Docker: redis://redis:6379
# For Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration (Optional - for event streaming)
# For Docker: kafka:29092
# For Local: localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=payment-service

# Feature Flags
CACHE_ENABLED=false
EVENT_BUS_ENABLED=false
WORKERS_ENABLED=false

# Logging
LOG_LEVEL=info
FILE_UPLOAD_SERVICE_URL=http://localhost:4100
FILE_DEFAULT_TENANT_ID=default