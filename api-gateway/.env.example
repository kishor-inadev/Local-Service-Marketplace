# ===============================================
# API GATEWAY CONFIGURATION
# ===============================================

# Application
NODE_ENV=development
PORT=3700
SERVICE_NAME=api-gateway

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Gateway Internal Secret (for auth service communication)
GATEWAY_INTERNAL_SECRET=gateway-internal-secret-change-in-production

# Token Validation Strategy
# Options: 'local' (JWT verification in gateway) or 'api' (call auth service)
# 'local' = faster, lower latency, gateway needs JWT_SECRET
# 'api' = centralized, can check user status, auth service dependency
TOKEN_VALIDATION_STRATEGY=local

# Microservice URLs (Merged Services)
# For Docker: Use container names
# For Local: Use localhost with appropriate ports
IDENTITY_SERVICE_URL=http://localhost:3001
MARKETPLACE_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3006
COMMS_SERVICE_URL=http://localhost:3007
OVERSIGHT_SERVICE_URL=http://localhost:3010
INFRASTRUCTURE_SERVICE_URL=http://localhost:3012
# Legacy aliases (backward compatibility)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3001
REQUEST_SERVICE_URL=http://localhost:3003
PROPOSAL_SERVICE_URL=http://localhost:3003
JOB_SERVICE_URL=http://localhost:3003
MESSAGING_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3007
REVIEW_SERVICE_URL=http://localhost:3003
ADMIN_SERVICE_URL=http://localhost:3010
ANALYTICS_SERVICE_URL=http://localhost:3010

# External Services
# For Docker: http://email-service:3500, http://sms-service:3000
# For Local: http://localhost:4000, http://localhost:5000
EMAIL_SERVICE_URL=http://localhost:4000
SMS_SERVICE_URL=http://localhost:5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Redis Configuration (Optional - for rate limiting and caching)
# For Docker: redis
# For Local: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Feature Flags for Optional Services
ANALYTICS_ENABLED=false
KAFKA_ENABLED=false
INFRASTRUCTURE_ENABLED=false
MESSAGING_ENABLED=false

# Logging
LOG_LEVEL=info
